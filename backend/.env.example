# Copy to .env and fill in. Never commit .env.

# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI=
# Database name (created automatically)
MONGODB_DB=portfolio

# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=
# Groq model (see https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile

# Admin token guarding the knowledge-base CRUD routes (/api/documents).
# Use a long random string. The frontend /admin page sends it as x-admin-token.
ADMIN_TOKEN=

# Server
PORT=4000
# Comma-separated allowed origins for CORS (the frontend URL). Use * for any.
CORS_ORIGIN=http://localhost:3000
